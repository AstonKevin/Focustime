{
  "name": "focus-ping",
  "version": "1.1.2",
  "description": "Random sound reminder focus timer - maintain attention with random notification sounds",
  "main": "electron/main.js",
  "author": "AstonKevin",
  "license": "MIT",
  "homepage": "https://github.com/AstonKevin/Focustime",
  "repository": {
    "type": "git",
    "url": "https://github.com/AstonKevin/Focustime.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.focus-timer.app",
    "productName": "FocusPing",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FocusPing",
      "installerIcon": "",
      "uninstallerIcon": "",
      "installerHeaderIcon": "",
      "allowElevation": true
    }
  }
}
